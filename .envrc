# uv manages the venv; direnv activates it
# Requires: uv, direnv >= 2.32 for `layout uv` OR use manual approach below

# If your direnv is new enough (>= 2.32):
# layout uv

# Manual approach (works everywhere):
uv venv --quiet 2>/dev/null || true
source .venv/bin/activate

if ! python -m ufbt --version &>/dev/null; then
    echo "[direnv] installing ufbt..."
    uv pip install --quiet ufbt
fi

# Keep SDK/toolchain local to the project instead of ~/.ufbt
export UFBT_HOME="$PWD/.ufbt"

# Pin SDK channel: release | dev | <version e.g. 0.106.2>
export UFBT_SDK_CHANNEL=release

# Uncomment for flashing over USB:
# export FLIP_PORT=/dev/ttyACM0
